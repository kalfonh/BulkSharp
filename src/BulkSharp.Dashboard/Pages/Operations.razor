@page "/bulks-list"
@using BulkSharp.Core.Domain.Operations
@using System.Net.Http.Json
@using BulkSharp.Core.Domain.Queries
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ILogger<Operations> Logger
@implements IDisposable

<PageTitle>Bulk Operations</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Operations</h1>
        <p>View and manage all bulk processing operations</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
        <a href="/create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Operation
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-0">Operation Name</label>
                <input type="text" class="form-control form-control-sm" placeholder="Search name..."
                       @bind="filterOperationName" @bind:event="oninput" @bind:after="OnFilterChanged" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Service</label>
                <select class="form-select form-select-sm" @bind="filterSource" @bind:after="OnFilterChanged">
                    <option value="">All Services</option>
                    @foreach (var svc in availableServices)
                    {
                        <option value="@svc">@svc</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Created By</label>
                <input type="text" class="form-control form-control-sm" placeholder="Search creator..."
                       @bind="filterCreatedBy" @bind:event="oninput" @bind:after="OnFilterChanged" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">Status</label>
                <select class="form-select form-select-sm" @bind="filterStatus" @bind:after="OnFilterChanged">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetValues<BulkOperationStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-0">From Date</label>
                <input type="date" class="form-control form-control-sm" @bind="filterFromDate" @bind:after="OnFilterChanged" />
            </div>
            <div class="col-md-1">
                <label class="form-label small mb-0">To Date</label>
                <input type="date" class="form-control form-control-sm" @bind="filterToDate" @bind:after="OnFilterChanged" />
            </div>
            <div class="col-md-1">
                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        @if (pagedResult == null)
        {
            <div class="text-center py-4">
                <div class="spinner-border spinner-border-sm text-primary"></div>
                <p class="text-muted mt-2 small">Loading operations...</p>
            </div>
        }
        else if (pagedResult.Items.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-inbox d-block"></i>
                <p>No operations found</p>
                <a href="/create" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Create First Operation
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="cursor:pointer;" @onclick='() => ToggleSort("OperationName")'>
                                Operation @SortIndicator("OperationName")
                            </th>
                            <th>Source</th>
                            <th style="cursor:pointer;" @onclick='() => ToggleSort("Status")'>
                                Status @SortIndicator("Status")
                            </th>
                            <th style="min-width: 140px; cursor:pointer;" @onclick='() => ToggleSort("ProcessedRows")'>
                                Progress @SortIndicator("ProcessedRows")
                            </th>
                            <th>File</th>
                            <th style="cursor:pointer;" @onclick='() => ToggleSort("CreatedAt")'>
                                Created @SortIndicator("CreatedAt")
                            </th>
                            <th>Duration</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bulk in pagedResult.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@bulk.OperationName</div>
                                    <small class="text-muted">@bulk.CreatedBy</small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-muted">@bulk.Source</span>
                                </td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(bulk.Status)">@bulk.Status</span>
                                </td>
                                <td>
                                    @if (bulk.TotalRows > 0)
                                    {
                                        var progress = (bulk.ProcessedRows * 100.0 / bulk.TotalRows);
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar @(bulk.Status == BulkOperationStatus.Failed ? "bg-danger" : "")"
                                                 style="width: @progress%"></div>
                                        </div>
                                        <small class="text-muted">@bulk.ProcessedRows / @bulk.TotalRows</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <small>@bulk.FileName</small>
                                    @if (bulk.FileSize > 0)
                                    {
                                        <br /><small class="text-muted">@FormatFileSize(bulk.FileSize)</small>
                                    }
                                </td>
                                <td>
                                    <small>@bulk.CreatedAt.ToString("MMM dd, yyyy")<br />@bulk.CreatedAt.ToString("HH:mm:ss")</small>
                                </td>
                                <td>
                                    @if (bulk.CompletedAt.HasValue)
                                    {
                                        <small>@FormatDuration(bulk.CompletedAt.Value - bulk.CreatedAt)</small>
                                    }
                                    else if (bulk.Status == BulkOperationStatus.Running)
                                    {
                                        <small class="text-info">@FormatDuration(DateTime.UtcNow - bulk.CreatedAt)</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/bulk/@bulk.Id" class="btn btn-outline-primary" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (bulk.Status == BulkOperationStatus.Running)
                                        {
                                            <button class="btn btn-outline-warning" title="Cancel" @onclick="() => CancelOperation(bulk.Id)">
                                                <i class="bi bi-stop-circle"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                <small class="text-muted">
                    Showing @(((currentPage - 1) * currentPageSize) + 1)–@Math.Min(currentPage * currentPageSize, pagedResult.TotalCount)
                    of @pagedResult.TotalCount
                </small>
                <div class="d-flex align-items-center gap-2">
                    <select class="form-select form-select-sm" style="width:auto;" @bind="currentPageSize" @bind:after="OnPageSizeChanged">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
                            </li>
                            @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(TotalPages, currentPage + 2); p++)
                            {
                                var page = p;
                                <li class="page-item @(page == currentPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(page)">@(page)</button>
                                </li>
                            }
                            <li class="page-item @(!pagedResult.HasNextPage ? "disabled" : "")">
                                <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">Next</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private PagedResult<BulkOperation>? pagedResult;

    // Filters
    private string filterOperationName = "";
    private string filterSource = "";
    private string filterCreatedBy = "";
    private string filterStatus = "";
    private List<string> availableServices = new();
    private DateTime? filterFromDate;
    private DateTime? filterToDate;

    // Pagination
    private int currentPage = 1;
    private int currentPageSize = 20;

    // Sorting
    private string sortBy = "CreatedAt";
    private bool sortDescending = true;

    private int TotalPages => pagedResult == null ? 1
        : (int)Math.Ceiling((double)pagedResult.TotalCount / currentPageSize);

    private System.Threading.Timer? debounceTimer;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        Http.BaseAddress ??= new Uri(Navigation.BaseUri);
        // Load available services from operations discovery
        try
        {
            var ops = await Http.GetFromJsonAsync<JsonElement[]>("api/operations");
            if (ops != null)
            {
                availableServices = ops
                    .Where(o => o.TryGetProperty("sourceService", out _))
                    .Select(o => o.GetProperty("sourceService").GetString()!)
                    .Where(s => !string.IsNullOrEmpty(s))
                    .Distinct()
                    .OrderBy(s => s)
                    .ToList();
            }
        }
        catch { /* standalone mode - no sourceService tags */ }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            Http.BaseAddress ??= new Uri(Navigation.BaseUri);
            BulkOperationStatus? status = Enum.TryParse<BulkOperationStatus>(filterStatus, out var parsed) ? parsed : null;

            var qs = $"api/bulks?page={currentPage}&pageSize={currentPageSize}&sortBy={sortBy}&sortDescending={sortDescending}";
            if (!string.IsNullOrEmpty(filterOperationName)) qs += $"&operationName={Uri.EscapeDataString(filterOperationName)}";
            if (!string.IsNullOrEmpty(filterSource)) qs += $"&source={Uri.EscapeDataString(filterSource)}";
            if (!string.IsNullOrEmpty(filterCreatedBy)) qs += $"&createdBy={Uri.EscapeDataString(filterCreatedBy)}";
            if (status.HasValue) qs += $"&status={status.Value}";
            if (filterFromDate.HasValue) qs += $"&fromDate={filterFromDate.Value:yyyy-MM-dd}";
            if (filterToDate.HasValue) qs += $"&toDate={filterToDate.Value:yyyy-MM-dd}";

            pagedResult = await Http.GetFromJsonAsync<PagedResult<BulkOperation>>(qs, _cts.Token);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load operations");
            pagedResult = new PagedResult<BulkOperation> { Items = [], TotalCount = 0, Page = 1, PageSize = currentPageSize };
        }
    }

    private void OnFilterChanged()
    {
        debounceTimer?.Dispose();
        debounceTimer = new System.Threading.Timer(async _ =>
        {
            currentPage = 1;
            await LoadData();
            await InvokeAsync(StateHasChanged);
        }, null, 300, Timeout.Infinite);
    }

    private async Task ClearFilters()
    {
        filterOperationName = "";
        filterSource = "";
        filterCreatedBy = "";
        filterStatus = "";
        filterFromDate = null;
        filterToDate = null;
        currentPage = 1;
        await LoadData();
    }

    private async Task OnPageSizeChanged()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        currentPage = page;
        await LoadData();
    }

    private void ToggleSort(string column)
    {
        if (sortBy == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortBy = column;
            sortDescending = column == "CreatedAt";
        }
        currentPage = 1;
        _ = LoadData().ContinueWith(_ => InvokeAsync(StateHasChanged));
    }

    private string SortIndicator(string column)
    {
        if (sortBy != column) return "";
        return sortDescending ? "\u25BC" : "\u25B2";
    }

    private async Task RefreshData()
    {
        pagedResult = null;
        await LoadData();
    }

    private async Task CancelOperation(Guid id)
    {
        try
        {
            Http.BaseAddress ??= new Uri(Navigation.BaseUri);
            await Http.PostAsync($"api/bulks/{id}/cancel", null, _cts.Token);
            await RefreshData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel operation {OperationId}", id);
        }
    }

    private string GetStatusBadgeClass(BulkOperationStatus status) => status switch
    {
        BulkOperationStatus.Pending => "bg-warning text-dark",
        BulkOperationStatus.Running => "bg-info text-white",
        BulkOperationStatus.Completed => "bg-success text-white",
        BulkOperationStatus.CompletedWithErrors => "bg-warning text-dark",
        BulkOperationStatus.Failed => "bg-danger text-white",
        BulkOperationStatus.Cancelled => "bg-secondary text-white",
        _ => "bg-light text-dark"
    };

    private string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1) { order++; len /= 1024; }
        return $"{len:0.##} {sizes[order]}";
    }

    private string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalSeconds < 60) return $"{duration.TotalSeconds:0}s";
        if (duration.TotalMinutes < 60) return $"{duration.TotalMinutes:0.0}m";
        return $"{duration.TotalHours:0.0}h";
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        debounceTimer?.Dispose();
    }
}
